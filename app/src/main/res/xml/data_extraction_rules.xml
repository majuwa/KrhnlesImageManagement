<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Exclude the credentials DataStore to prevent server URL leaking via cloud backup -->
    <cloud-backup>
        <exclude domain="file" path="datastore/credentials.preferences_pb"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/credentials.preferences_pb"/>
    </device-transfer>
</data-extraction-rules>